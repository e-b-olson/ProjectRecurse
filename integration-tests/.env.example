# Required: explicit opt-in so tests never run against production by accident
INTEGRATION_TESTS_ENABLED=true

# Supabase API (local: `supabase status` → API URL + anon key + service_role key)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Optional: restrict runs to a single project ref (e.g. local default abcdefghijklmnop)
# SUPABASE_ALLOWED_PROJECT_REF=abcdefghijklmnopqrst

# Optional: comma-separated extra host patterns (default allows localhost / 127.0.0.1)
# SUPABASE_ALLOWED_HOSTS=localhost,127.0.0.1
