NEXT_PUBLIC_SUPABASE_URL=FOO
# Supabase dashboard → Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=BAR
# Legacy name (optional if PUBLISHABLE_KEY is set):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=BAR

# Direct Postgres connection for Drizzle migrations (never exposed to the client)
# Find this in Supabase: Project Settings → Database → Connection string → URI
# Use the "Transaction" mode URL (port 6543) for serverless, or "Session" mode (port 5432) for migrations
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres